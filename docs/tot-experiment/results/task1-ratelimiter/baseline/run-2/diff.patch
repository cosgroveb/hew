 func newLimiter(cfg Config, clock Clock) Limiter {
-	return nil
+	// Normalise burst: if zero use rate as burst.
+	burst := cfg.Burst
+	if burst <= 0 {
+		burst = cfg.Rate
+	}
+
+	// Defensive defaults: non‑positive rate or window makes limiter a no‑op.
+	if cfg.Rate <= 0 || cfg.Window <= 0 {
+		return &noOpLimiter{}
+	}
+
+	// Use the provided clock, or fall back to real time.
+	var c Clock = clock
+	if c == nil {
+		c = realClock{}
+	}
+
+	return &bucketLimiter{
+		cfg: Config{
+			Rate:   cfg.Rate,
+			Window: cfg.Window,
+			Burst:  burst,
+		},
+		clk:   c,
+		state: make(map[string]*bucketState),
+		mu:    &sync.RWMutex{},
+	}
