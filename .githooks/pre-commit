#!/bin/bash
# Pre-commit hook: detect obvious binary symmetry gaps in hew/hui
# Runs before `git commit` to catch missing flags in either binary
#
# Note: This is a lightweight check. For comprehensive symmetry audit,
# use the /review-symmetry skill during code review.

set -e

# Only check if we're about to commit changes to cmd/hew/ or cmd/hui/
if ! git diff --cached --name-only | grep -qE 'cmd/(hew|hui)/'; then
    exit 0
fi

# Extract all flag declarations from both binaries
# Pattern: flags.String("foo", ... → captures "foo"
hew_flags=$(grep -oP 'flags\.\w+\("([^"]+)"' cmd/hew/main.go 2>/dev/null | cut -d'"' -f2 | sort -u || echo "")
hui_flags=$(grep -oP 'flags\.\w+\("([^"]+)"' cmd/hui/main.go 2>/dev/null | cut -d'"' -f2 | sort -u || echo "")

# Check for flags in one binary but not the other
hew_only=$(echo "$hew_flags" | grep -Fxvf <(echo "$hui_flags") || true)
hui_only=$(echo "$hui_flags" | grep -Fxvf <(echo "$hew_flags") || true)

if [ -n "$hew_only" ] || [ -n "$hui_only" ]; then
    echo ""
    echo "⚠ Binary flag asymmetry detected!"
    [ -n "$hew_only" ] && echo "  In cmd/hew but not cmd/hui: $(echo "$hew_only" | tr '\n' ' ')"
    [ -n "$hui_only" ] && echo "  In cmd/hui but not cmd/hew: $(echo "$hui_only" | tr '\n' ' ')"
    echo ""
    echo "Before committing, verify this is intentional."
    echo "Use '/review-symmetry' during code review for a comprehensive audit."
    echo ""
    exit 1
fi

exit 0
